# Local Development
VITE_API_URL=http://localhost:5002/api

# Production (Vercel + Render)
# Replace with your Render backend URL after deployment
VITE_API_URL=https://your-backend-app.onrender.com/api

# Deployment Instructions:
# 1. Deploy backend to Render first
# 2. Copy the Render URL (e.g., https://your-app.onrender.com)
# 3. Replace 'your-backend-app.onrender.com' above with your actual Render URL
# 4. Add this URL to Vercel environment variables
# 5. In Render, add CLIENT_URL environment variable with your Vercel URL

